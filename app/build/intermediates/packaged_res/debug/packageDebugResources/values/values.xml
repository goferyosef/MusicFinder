<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="background">#FFFBFE</color>
    <color name="divider">#CAC4D0</color>
    <color name="primary">#6750A4</color>
    <color name="primary_variant">#4F378B</color>
    <color name="surface">#FFFBFE</color>
    <color name="text_primary">#1C1B1F</color>
    <color name="text_secondary">#49454F</color>
    <string name="app_name">MusicFinder</string>
    <style name="Theme.MusicFinder" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
    </style>
    <style name="Theme.MusicFinder.Translucent" parent="Theme.MusicFinder">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
    </style>
</resources>