<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Required on Android 11+ to detect if Brave browser is installed -->
    <queries>
        <package android:name="com.brave.browser" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_music_note"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_music_note"
        android:supportsRtl="true"
        android:theme="@style/Theme.MusicFinder">

        <!-- Main launcher screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receives shared text from Libby, browsers, PDF readers, etc. -->
        <activity
            android:name=".ShareActivity"
            android:exported="true"
            android:theme="@style/Theme.MusicFinder.Translucent">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Camera + OCR entry point -->
        <activity
            android:name=".CameraActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>

</manifest>
