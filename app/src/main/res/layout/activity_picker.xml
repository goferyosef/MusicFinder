<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/picker_bg">

    <!-- Header -->
    <TextView
        android:id="@+id/headerText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Searching…"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/green_dark"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="10dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/green_divider"
        android:layout_marginHorizontal="16dp" />

    <!-- Loading animation block -->
    <LinearLayout
        android:id="@+id/loadingBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="28dp">

        <!-- Spinning music note -->
        <ImageView
            android:id="@+id/spinningNote"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_music_note"
            android:layout_marginBottom="16dp"
            android:contentDescription="searching" />

        <!-- Funny rotating message -->
        <TextView
            android:id="@+id/funnyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bribing the DJ…"
            android:textSize="14sp"
            android:textColor="@color/green_medium"
            android:fontFamily="sans-serif"
            android:textStyle="italic"
            android:gravity="center" />
    </LinearLayout>

    <!-- Results list (hidden while loading) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:nestedScrollingEnabled="false"
        android:visibility="gone" />

</LinearLayout>
